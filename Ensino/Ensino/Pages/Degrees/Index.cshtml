@page
@model Ensino.Pages.Degrees.IndexModel

@{
    ViewData["Title"] = "Cursos";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Criar novo curso</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ListOfDegrees[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ListOfDegrees[0].Logotype)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.ListOfDegrees) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Logotype)
            </td>

            <td>
                <img src="~/images/@item.Logotype"
                alt="Imagem do logótipo do curso @item.Name"
                style="height:50px; width: auto; border: 5px;"/>
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Editar</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Detalhes</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Apagar</a>
            </td>
        </tr>
}
    </tbody>
</table>
